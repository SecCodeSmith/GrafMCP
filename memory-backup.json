    {
      "name": "Book 1",
      "type": "book",
      "created": "2026-07-17T18:59:34.996Z",
      "updated": "2026-07-17T19:00:33.564Z",
      "observations": [
        {
          "id": 411,
          "text": "Book 1: The Moon's Frontier. Status: planned, 18 chapters. Act 1: The Departure (Ch 1-4). Act 2: The Frontier (Ch 5-8). Act 3: The Awakening (Ch 9-13). Act 4: The Envoy (Ch 14-18).",
          "created": "2026-07-17T18:59:35.013Z"
        }
      ]
    },
    {
      "name": "Cornelia",
      "type": "character",
      "created": "2026-07-17T18:59:21.203Z",
      "updated": "2026-07-17T18:59:21.203Z",
      "observations": [
        {
          "id": 402,
          "text": "Daughter of Julius and Gates. A powerful Perpetual born with sealed powers.",
          "created": "2026-07-17T18:59:21.212Z"
        },
        {
          "id": 403,
          "text": "Wears platinum power armor forged by Mulciber.",
          "created": "2026-07-17T18:59:21.216Z"
        }
      ]
    },
    {
      "name": "Horus",
      "type": "character",
      "created": "2026-07-17T18:59:23.184Z",
      "updated": "2026-07-17T18:59:23.184Z",
      "observations": [
        {
          "id": 408,
          "text": "Primarch of the Luna Wolves. Meets Julius in the Frontier before the Heresy.",
          "created": "2026-07-17T18:59:23.198Z"
        }
      ]
    },
    {
      "name": "Julius Coperium / Jack Cooper",
      "type": "character",
      "created": "2026-07-17T18:59:19.423Z",
      "updated": "2026-07-17T19:00:01.572Z",
      "observations": [
        {
          "id": 396,
          "text": "The biological son of the Emperor, born in ancient Rome. Equal in power to the Emperor.",
          "created": "2026-07-17T18:59:19.456Z"
        },
        {
          "id": 397,
          "text": "Sealed his memory to live as Jack Cooper, Rifleman 3rd Class and Hero of Typhon.",
          "created": "2026-07-17T18:59:19.475Z"
        }
      ]
    },
    {
      "name": "Lion El'Jonson",
      "type": "character",
      "created": "2026-07-17T18:59:22.725Z",
      "updated": "2026-07-17T18:59:22.725Z",
      "observations": [
        {
          "id": 407,
          "text": "Primarch of the Dark Angels. Commands the diplomatic envoy to the Frontier.",
          "created": "2026-07-17T18:59:22.739Z"
        }
      ]
    },
    {
      "name": "Mercurius",
      "type": "character",
      "created": "2026-07-17T18:59:23.214Z",
      "updated": "2026-07-17T18:59:23.214Z",
      "observations": [
        {
          "id": 409,
          "text": "The Explorer. One of the six Primarchs of Julius. Boyish and wry.",
          "created": "2026-07-17T18:59:23.222Z"
        }
      ]
    },
    {
      "name": "Quirinus",
      "type": "character",
      "created": "2026-07-17T18:59:23.259Z",
      "updated": "2026-07-17T18:59:23.259Z",
      "observations": [
        {
          "id": 410,
          "text": "The Defender. One of the six Primarchs of Julius. Wears iron-grey armor with a tower shield.",
          "created": "2026-07-17T18:59:23.268Z"
        }
      ]
    },
    {
      "name": "Roboute Guilliman",
      "type": "character",
      "created": "2026-07-17T18:59:22.163Z",
      "updated": "2026-07-17T18:59:22.163Z",
      "observations": [
        {
          "id": 406,
          "text": "Lord Commander of the Imperium, Primarch of the Ultramarines.",
          "created": "2026-07-17T18:59:22.172Z"
        }
      ]
    },
    {
      "name": "Rule 10: Flavor bends",
      "type": "rule",
      "created": "2026-07-17T18:58:58.184Z",
      "updated": "2026-07-17T18:58:58.184Z",
      "observations": [
        {
          "id": 395,
          "text": "WW2 and the Aquila's father-son origin are AU flavor. The story treats Julius's Aquila as a private pre-Treaty symbol.",
          "created": "2026-07-17T18:58:58.193Z"
        }
      ]
    },
    {
      "name": "Rule 1: Departure date",
      "type": "rule",
      "created": "2026-07-17T18:58:53.671Z",
      "updated": "2026-07-17T18:59:49.089Z",
      "observations": [
        {
          "id": 386,
          "text": "Julius leaves Terra circa M30 after the Thunder Warriors purge begins, before the Scattering of the Primarchs.",
          "created": "2026-07-17T18:58:53.678Z"
        }
      ]
    },
    {
      "name": "Rule 2: The erasure",
      "type": "rule",
      "created": "2026-07-17T18:58:54.370Z",
      "updated": "2026-07-17T18:59:49.145Z",
      "observations": [
        {
          "id": 387,
          "text": "The Emperor personally erased Julius from all Imperial records; Custodes are oath-bound to silence. Horus's suppressed report deepened an existing void.",
          "created": "2026-07-17T18:58:54.396Z"
        }
      ]
    },
    {
      "name": "Rule 3: The gift",
      "type": "rule",
      "created": "2026-07-17T18:58:55.037Z",
      "updated": "2026-07-17T18:58:55.037Z",
      "observations": [
        {
          "id": 388,
          "text": "The 100 Custodians are a permanent, explicit gift from the Emperor. The Tribune and 40 assigned during Primarch project; 60 granted at departure. The 100 grew to fifteen thousand over ten millennia.",
          "created": "2026-07-17T18:58:55.044Z"
        }
      ]
    },
    {
      "name": "Rule 4: Time",
      "type": "rule",
      "created": "2026-07-17T18:58:55.714Z",
      "updated": "2026-07-17T18:58:55.714Z",
      "observations": [
        {
          "id": 389,
          "text": "Time inside the anomaly is unanchored from the materium: ~10,000 years outside ≈ a few centuries of Frontier history plus Jack's lifetime inside. No fixed ratio.",
          "created": "2026-07-17T18:58:55.727Z"
        }
      ]
    },
    {
      "name": "Rule 5: Fold-tech",
      "type": "rule",
      "created": "2026-07-17T18:58:56.252Z",
      "updated": "2026-07-17T18:58:56.252Z",
      "observations": [
        {
          "id": 390,
          "text": "Fold technology is Julius's DAoT-archive tech. The Typhon Fold Weapon was a lost fragment of early Frontier infrastructure. Weapon and Ark are relics of Julius's early fold infrastructure.",
          "created": "2026-07-17T18:58:56.260Z"
        }
      ]
    },
    {
      "name": "Rule 6: The fabricated Frontier",
      "type": "rule",
      "created": "2026-07-17T18:58:56.819Z",
      "updated": "2026-07-17T18:58:56.819Z",
      "observations": [
        {
          "id": 391,
          "text": "The entire Frontier is Julius's creation (woven memory). The corporate seed grew into the IMC. The Frontier War is his unintended consequence.",
          "created": "2026-07-17T18:58:56.850Z"
        }
      ]
    },
    {
      "name": "Rule 7: The decree",
      "type": "rule",
      "created": "2026-07-17T18:58:57.503Z",
      "updated": "2026-07-17T18:58:57.503Z",
      "observations": [
        {
          "id": 392,
          "text": "Julius forbade his legions from intervening in colonist affairs. The Moon fleet and six legions hold the anomaly rim, unseen.",
          "created": "2026-07-17T18:58:57.517Z"
        }
      ]
    },
    {
      "name": "Rule 8: The seal",
      "type": "rule",
      "created": "2026-07-17T18:58:58.115Z",
      "updated": "2026-07-17T18:58:58.115Z",
      "observations": [
        {
          "id": 393,
          "text": "Julius sealed himself for one honest mortal life. The six Primarchs held stewardship. Unsealing condition: harm to his people that he could not bear.",
          "created": "2026-07-17T18:58:58.132Z"
        }
      ]
    },
    {
      "name": "Rule 9: Power ceiling",
      "type": "rule",
      "created": "2026-07-17T18:58:58.153Z",
      "updated": "2026-07-17T18:58:58.153Z",
      "observations": [
        {
          "id": 394,
          "text": "Julius is equal or stronger than the Emperor. Stakes NEVER come from 'can they win'. Threats must be indirect (hostages, corruption, politics). No frontal boss fight.",
          "created": "2026-07-17T18:58:58.162Z"
        }
      ]
    },
    {
      "name": "Sarah Briggs",
      "type": "character",
      "created": "2026-07-17T18:59:21.608Z",
      "updated": "2026-07-17T18:59:21.608Z",
      "observations": [
        {
          "id": 404,
          "text": "Commander of the Frontier Militia's Marauder Corps / 9th Fleet.",
          "created": "2026-07-17T18:59:21.618Z"
        },
        {
          "id": 405,
          "text": "Lobotomized by the Imperial compliance fleet, breaking Julius's seal.",
          "created": "2026-07-17T18:59:21.624Z"
        }
      ]
    },
    {
      "name": "Sophia Gates (Gates)",
      "type": "character",
      "created": "2026-07-17T18:59:20.647Z",
      "updated": "2026-07-17T18:59:20.647Z",
      "observations": [
        {
          "id": 400,
          "text": "Commander of the 6-4 mercenary faction. Stubborn, warm, incredibly perceptive.",
          "created": "2026-07-17T18:59:20.654Z"
        },
        {
          "id": 401,
          "text": "Wife of Julius and mother of Cornelia.",
          "created": "2026-07-17T18:59:20.659Z"
        }
      ]
    },
    {
      "name": "The Rejection of Terra",
      "type": "plot_thread",
      "created": "2026-07-17T18:59:49.065Z",
      "updated": "2026-07-17T18:59:49.065Z",
      "observations": []
    },
    {
      "name": "The Tribune",
      "type": "character",
      "created": "2026-07-17T18:59:20.019Z",
      "updated": "2026-07-17T18:59:20.019Z",
      "observations": [
        {
          "id": 398,
          "text": "Julius's personal guardian, chosen from the Hetaeron Guard.",
          "created": "2026-07-17T18:59:20.032Z"
        },
        {
          "id": 399,
          "text": "Silent, clever, wears pristine silver-gold armor. Commands the Custodians.",
          "created": "2026-07-17T18:59:20.039Z"
        }
      ]
    }
  ],
